{{ ansible_managed | comment }}
# Redirect HTTP to HTTPS
server {
    listen 80;
    listen [::]:80;
    server_name dsm.{{ rtv_domain }} *.{{ rtv_domain }};
    return 301 https://$host$request_uri;
}

# Redirect root domain to www
server {
    listen 80;
    listen [::]:80;
    listen 443 ssl http2;
    listen [::]:443 ssl http2;
    server_name {{ rtv_domain }};

    ssl_certificate {{ nginx_rtv_ssl_certificate }};
    ssl_certificate_key {{ nginx_rtv_ssl_certificate_key }};

    return 301 https://www.{{ rtv_domain }}$request_uri;
}

server {
    listen 443 ssl http2;
    listen [::]:443 ssl http2;
    server_name www.{{ rtv_domain }};

    ssl_certificate {{ nginx_rtv_ssl_certificate }};
    ssl_certificate_key {{ nginx_rtv_ssl_certificate_key }};

    access_log {{ nginx_sites_logs }}/access-www.{{ rtv_domain }}.log {{ nginx_access_log_options }};
    error_log {{ nginx_sites_logs }}/error-www.{{ rtv_domain }}.log {{ nginx_error_log_options }};

    location / {
        return 404;
    }
}

server {
    listen 443 ssl http2;
    listen [::]:443 ssl http2;
    server_name dsm.{{ rtv_domain }};

    ssl_certificate {{ nginx_rtv_ssl_certificate }};
    ssl_certificate_key {{ nginx_rtv_ssl_certificate_key }};

    access_log {{ nginx_sites_logs }}/access-dsm.{{ rtv_domain }}.log {{ nginx_access_log_options }};
    error_log {{ nginx_sites_logs }}/error-dsm.{{ rtv_domain }}.log {{ nginx_error_log_options }};

    location / {
        proxy_pass http://10.1.0.5:5000/;
        proxy_set_header    Host $host;
        proxy_set_header    X-Real-IP $remote_addr;
        proxy_set_header    X-Forwarded-For $proxy_add_x_forwarded_for;
    }
}
