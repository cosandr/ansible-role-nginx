{{ ansible_managed | comment }}
server {
    listen 127.0.0.1:80;
    listen {{ ansible_facts.default_ipv4.address }}:80;
    allow 127.0.0.1;
    allow {{ ansible_facts.default_ipv4.network }}/24;
    deny all;
    location /{{ nginx_status_url }} {
        stub_status on;
        access_log off;
        allow 127.0.0.1;
        # Allow all internal IPs as well, mostly for containers/VMs
{% for item in ansible_all_ipv4_addresses %}
        allow {{ item | regex_replace('(.*)\\.\\d+$', '\\1.0') }}/24;
{% endfor %}
        deny all;
    }

    proxy_redirect                     off;
    proxy_set_header Host              $http_host;
    proxy_set_header X-Real-IP         $remote_addr;
    proxy_set_header X-Forwarded-For   $proxy_add_x_forwarded_for;
    proxy_set_header X-Forwarded-Proto $scheme;
{% for key in ports.keys() %}

    location /{{ key }} {
        proxy_pass http://{{ key }};
    }
{% endfor %}
}
